@{
    ViewData["Title"] = "Quản lý danh mục menu";
}

<!-- DataTales Example -->
<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex flex-row justify-content-between align-items-center bg-gradient-primary">
        <h6 class="m-0 font-weight-bold text-white">
            <i class="fas fa-users me-2"></i>Quản lý danh mục menu
        </h6>
        <button class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#modal-add">
            <i class="fas fa-plus-circle me-1"></i>Thêm danh mục menu
        </button>
    </div>
    <div class="card-body">
        <!-- Search and Filter Row -->
        <div class="row mb-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i class="fas fa-search text-primary"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm theo tên hoặc tài khoản...">
                    <button class="btn btn-outline-primary" type="button" id="searchBtn">
                        <i class="fas fa-search"></i> Tìm
                    </button>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-bordered" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>STT</th>
                        <th>Tiều đề</th>
                        <th>Icon</th>
                        <th>Trạng thái</th>
                        <th>Thứ tự</th>

                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="titleMenuTableBody">
                    <!-- Data will be loaded here -->
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="row mt-3">
            <div class="col-md-6">
                <div class="text-muted small" id="paginationInfo"></div>
            </div>
            <div class="col-md-6">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-end" id="pagination">
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit TitleMenu Modal -->
<div class="modal fade" id="modal-add" tabindex="-1" aria-labelledby="addTitleMenuModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="addTitleMenuModalLabel">
                    <i class="fas fa-plus-circle me-2"></i><span id="modalTitle">Thêm danh mục menu</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="titleMenuForm">
                    <input type="hidden" id="Id" name="Id">
                    <div class="mb-3">
                        <label for="title" class="form-label required">Tiêu Đề</label>
                        <input type="text" class="form-control" id="title" name="title" required>
                        <div class="invalid-feedback">Vui lòng nhập tiêu đề</div>
                    </div>
                    <div class="mb-3">
                        <label for="icon" class="form-label">Icon</label>
                        <input type="text" class="form-control" id="thumnail" name="thumnail" placeholder="bi bi-1-square-fill"></i>
                        <small class="text-muted">Bootstrap Icons: https://icons.getbootstrap.com/</small>
                    </div>
                    <div class="mb-3">
                        <label for="order" class="form-label">Thứ Tự</label>
                        <input type="number" class="form-control" id="order" name="order" min="1">
                    </div>
                    <div>
                        <label for="isActive" class="form-label">Trạng Thái</label>
                        <select class="form-select" id="status" name="status">
                            <option value="true">Hoạt Động</option>
                            <option value="false">Khoá</option>
                        </select>
                    </div>

             
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Đóng
                </button>
                <button type="button" class="btn btn-primary" id="saveTitleMenu">
                    <i class="fas fa-save me-1"></i>Lưu
                </button>
            </div>
        </div>
    </div>
</div>



<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteUserModalLabel">
                    <i class="fas fa-trash-alt me-2"></i>Xác nhận xoá
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xoá danh mục menu <strong id="deleteUserName"></strong>?</p>
                <p class="text-danger mb-0"><small>Hành động này không thể hoàn tác!</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Huỷ
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fas fa-trash-alt me-1"></i>Xoá
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/core/apiClient.js"></script>
    
    <script>
      
  

  

        var currentPage = 1;
        var pageSize = 3;
        var editingUserId = null;

        $(document).ready(function () {
            let searchKeyword = $('#searchInput').val(); 
            loadUsers(searchKeyword, currentPage, pageSize);
            // Save new user or update existing
            $(document).on('click', '#saveTitleMenu, #updateTitleMenu', function() {

                const titleMenuApi = new ApiClient('/api/tao-danh-muc-menu', {
                         modalSelector: '#modal-add',
                         formSelector: '#titleMenuForm'
                        });
              
                const formData = new FormData($('#titleMenuForm')[0]);
                
                if (editingUserId) {
                    // Update existing user
                    updateUser(editingUserId);
                } else {
                    // Create new user
                    titleMenuApi.post(formData, {
                     
                        hideModal: true,
                        resetForm: true,
                        callback: function(response) {
                            editingUserId = null;
                        
                           loadUsers($('#searchInput').val(), currentPage, pageSize);
                        }
                    });
                }
            });
            $('#modal-add').on('hidden.bs.modal', function () {
                resetForm();
      
            });

            // Search functionality
            $('#searchBtn').click(function() {
                currentPage = 1;
                let searchKeyword = $('#searchInput').val();
                loadUsers(searchKeyword, currentPage, pageSize);
            });

            // Search on Enter keygit add .

            $('#searchInput').keypress(function(e) {
                if (e.which === 13) {
                    $('#searchBtn').click();
                    return false;
                }
            });

         
        });

        /**
         * Tải danh sách người dùng
         */
        function loadUsers(searchKeyword, page, pageSize) {
            var listUserApi = new ApiClient('/api/lay-danh-sach-menu-chinh');
            const formData = new FormData();
            formData.append('search', searchKeyword);
            formData.append('page', page);
            formData.append('pagesize', pageSize);

            listUserApi.post(formData, {
                hideModal: false,
                resetForm: false,
                showMessage: false,
                callback: function(response) {
                    if (response.success && response.data) {
                        renderTitleMenuTable(response.data);
                        renderPagination(response.totalPages, page);
                    }
                }
            });
        }

        /**
         * Render bảng người dùng
         */
        function renderTitleMenuTable(titleMenus) {
            console.log('TitleMenus data:', titleMenus);
            let html = '';
            titleMenus.forEach((titleMenu, index) => {
                let stt = (currentPage - 1) * pageSize + index + 1;
                const statusBadge = titleMenu.status 
                    ? '<span class="badge bg-success">Hoạt động</span>' 
                    : '<span class="badge bg-danger">Khoá</span>';
                
                html += `
                    <tr>
                        <td>${ stt}</td>
                        <td>${titleMenu.title}</td>
                        <td><i class="${titleMenu.thumnail}"></i></td>
                        <td>${statusBadge}</td>
                        <td>${titleMenu.order}</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-info edit-btn" onclick="editTitleMenu('${titleMenu.id}')">
                                <i class="fas fa-edit"></i> Sửa
                            </button>
                  
                            <button class="btn btn-sm btn-danger" onclick="deleteTitleMenu('${titleMenu.id}', '${titleMenu.title}')">
                                <i class="fas fa-trash"></i> Xoá
                            </button>
                        </td>
                    </tr>
                `;
            });
            $('#titleMenuTableBody').html(html);
        }

        /**
         * Render pagination
         */
        function renderPagination(totalPages, currentPageNum) {
            let paginationHtml = '';
            
            // Previous button
            if (currentPageNum > 1) {
                paginationHtml += `<li class="page-item"><a class="page-link" href="#" onclick="changePage(${currentPageNum - 1})">Trước</a></li>`;
            }

            // Page numbers
            for (let i = 1; i <= totalPages; i++) {
                if (i === currentPageNum) {
                    paginationHtml += `<li class="page-item active"><span class="page-link">${i}</span></li>`;
                } else {
                    paginationHtml += `<li class="page-item"><a class="page-link" href="#" onclick="changePage(${i})">${i}</a></li>`;
                }
            }

            // Next button
            if (currentPageNum < totalPages) {
                paginationHtml += `<li class="page-item"><a class="page-link" href="#" onclick="changePage(${currentPageNum + 1})">Sau</a></li>`;
            }

            $('#pagination').html(paginationHtml);
            $('#paginationInfo').text(`Trang ${currentPageNum} / ${totalPages}`);
        }

        /**
         * Chuyển trang
         */
        function changePage(pageNum) {
            currentPage = pageNum;
            let searchKeyword = $('#searchInput').val();
            loadUsers(searchKeyword, currentPage, pageSize);
            return false;
        }

        /**
         * Chỉnh sửa danh mục menu
         */
        function editTitleMenu(titleMenuId) {
            editingUserId = titleMenuId;
           
            // Tạo API client để lấy thông tin danh mục menu
            const getApi = new ApiClient(`/api/chi-tiet-danh-muc-menu/${titleMenuId}`);
            getApi.get({}, {
                callback: function(response) {
                    if (response.success && response.data) {
                        const titleMenu = response.data;
                        console.log('TitleMenu data:', titleMenu);    
                        $('#Id').val(titleMenu.id);
                        $('#title').val(titleMenu.title);
                        $('#thumnail').val(titleMenu.thumnail);
                        $('#order').val(titleMenu.order);
                        $('#status').val(titleMenu.status.toString());
                        $('#addTitleMenuModalLabel').text('Chỉnh sửa danh mục menu');
                        $('#modalTitle').text('Chỉnh sửa danh mục menu');
                        $('#modal-add').modal('show');
                        $('#saveTitleMenu').attr('id', 'updateTitleMenu');
                    }
                }
            });
        }

        /**
         * Xóa danh mục menu
         */
        function deleteTitleMenu(id, userName) {
            $('#deleteUserName').text(userName);
            $('#deleteUserModal').modal('show');
            // Xoá event handler cũ và gắn handler mới BÊN TRONG hàm
            $('#confirmDeleteBtn').off('click').on('click', function() {
                // Tạo API client để xoá danh mục menu
                const deleteApi = new ApiClient(`/api/xoa-menu-chinh/${id}`);
                deleteApi.delete({}, {
                    hideModal: false,
                    resetForm: false,
                    showMessage: true,
                    callback: function(response) {
                        console.log('xoá thành công ');
                        $('#deleteUserModal').modal('hide');
                        currentPage = 1;
                        loadUsers($('#searchInput').val(), currentPage, pageSize);
                    }
                });
            });
        }
        /**
         * Reset form thêm mới
         */
        function resetForm() {
            editingUserId = null;
            $('#Id').val('');
            $('#titleMenuForm')[0].reset();
            $('#addTitleMenuModalLabel').text('Thêm danh mục menu');
            $('#modalTitle').text('Thêm danh mục menu');
            $('#updateTitleMenu').attr('id', 'saveTitleMenu');
        }
           /**
         * cập nhật danh mục menu
         */
        function updateUser(userId) {
            const formData = new FormData($('#titleMenuForm')[0]);
            const updateApi = new ApiClient(`/api/cap-nhat-danh-muc-menu/${userId}`, {
                modalSelector: '#modal-add',
                formSelector: '#titleMenuForm'
            });
            updateApi.put(formData, {
                successMessage: "Cập nhật danh mục menu thành công!",
                errorMessage: "Cập nhật thất bại!",
                hideModal: true,
                resetForm: true,
                showMessage: true,
                callback: function(response) {
                    editingUserId = null;
                    loadUsers($('#searchInput').val(), currentPage, pageSize);
                }
            });
        }

    </script>
}
@section Styles {
    <style>
        .required:after {
            content: " *";
            color: red;
        }

        .table-hover tbody tr:hover {
            background-color: #f5f5f5;
            cursor: pointer;
        }

        .page-item.active .page-link {
            background-color: #4e73df;
            border-color: #4e73df;
        }

        .bg-gradient-primary {
            background: linear-gradient(180deg, #4e73df 10%, #224abe 100%);
        }

        .badge {
            padding: 0.5rem 0.75rem;
            font-weight: 500;
        }

        .btn-sm {
            padding: 0.25rem 0.5rem;
        }
    </style>
}
