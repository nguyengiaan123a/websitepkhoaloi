@{
    ViewData["Title"] = "Quản lý tiêu đề menu";
}

<!-- DataTales Example -->
<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex flex-row justify-content-between align-items-center bg-gradient-primary">
        <h6 class="m-0 font-weight-bold text-white">
            <i class="fas fa-users me-2"></i>Quản lý menu
        </h6>
        <button class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#modal-add">
            <i class="fas fa-plus-circle me-1"></i>Thêm tiều đề menu
        </button>
    </div>
    <div class="card-body">
        <!-- Search and Filter Row -->
        <div class="row mb-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i class="fas fa-search text-primary"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm theo tên hoặc tài khoản...">
                    <button class="btn btn-outline-primary" type="button" id="searchBtn">
                        <i class="fas fa-search"></i> Tìm
                    </button>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-bordered" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>STT</th>
                        <th>Tiều đề</th>
                        <th>Icon</th>
            
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="titleMenuTableBody">
                    <!-- Data will be loaded here -->
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="row mt-3">
            <div class="col-md-6">
                <div class="text-muted small" id="paginationInfo"></div>
            </div>
            <div class="col-md-6">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-end" id="pagination">
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit TitleMenu Modal -->
<div class="modal fade" id="modal-add" tabindex="-1" aria-labelledby="addTitleMenuModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="addTitleMenuModalLabel">
                    <i class="fas fa-plus-circle me-2"></i><span id="modalTitle">Thêm Menu Chính Mới</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="titleMenuForm">
                    <input type="hidden" id="titleMenuId" name="titleMenuId">
                    <div class="mb-3">
                        <label for="title" class="form-label required">Tiêu Đề</label>
                        <input type="text" class="form-control" id="title" name="title" required>
                        <div class="invalid-feedback">Vui lòng nhập tiêu đề</div>
                    </div>
                    <div class="mb-3">
                        <label for="icon" class="form-label">Icon</label>
                        <input type="text" class="form-control" id="icon" name="icon" placeholder="VD: bi-home">
                        <small class="text-muted">Bootstrap Icons: https://icons.getbootstrap.com/</small>
                    </div>
                    <div class="mb-3">
                        <label for="thumnail" class="form-label">Hình Ảnh</label>
                        <input type="text" class="form-control" id="thumnail" name="thumnail" placeholder="URL hình ảnh">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Đóng
                </button>
                <button type="button" class="btn btn-primary" id="saveUser">
                    <i class="fas fa-save me-1"></i>Lưu
                </button>
            </div>
        </div>
    </div>
</div>



<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteUserModalLabel">
                    <i class="fas fa-trash-alt me-2"></i>Xác nhận xoá
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xoá người dùng <strong id="deleteUserName"></strong>?</p>
                <p class="text-danger mb-0"><small>Hành động này không thể hoàn tác!</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Huỷ
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fas fa-trash-alt me-1"></i>Xoá
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/core/apiClient.js"></script>
    
    <script>
        // Khởi tạo API clients
        const userApi = new ApiClient('/api/dang-ky-tai-khoan', {
            modalSelector: '#modal-add',
            formSelector: '#userForm'
        });

        const listUserApi = new ApiClient('/api/lay-danh-sach-nguoi-dung');

        var currentPage = 1;
        var pageSize = 20;
        var editingUserId = null;

        $(document).ready(function () {
            let searchKeyword = $('#searchInput').val(); 
            loadUsers(searchKeyword, currentPage, pageSize);

            // Reset form khi mở modal thêm mới
          // Thay đổi từ 'show.bs.modal' thành 'shown.bs.modal'
   
            // Toggle password visibility
            $('#togglePassword').click(function () {
                const passwordInput = $('#password');
                const icon = $(this).find('i');
                if (passwordInput.attr('type') === 'password') {
                    passwordInput.attr('type', 'text');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                } else {
                    passwordInput.attr('type', 'password');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                }
            });

            // Save new user or update existing
            $(document).on('click', '#saveUser, #updateUser', function() {
              
                const formData = new FormData($('#userForm')[0]);
                
                if (editingUserId) {
                    // Update existing user
                    updateUser(editingUserId);
                } else {
                    // Create new user
                    userApi.post(formData, {
                        hideModal: true,
                        resetForm: true,
                        callback: function(response) {
                            editingUserId = null;
                            currentPage = 1;
                            loadUsers($('#searchInput').val(), currentPage, pageSize);
                        }
                    });
                }
            });
            $('#modal-add').on('hidden.bs.modal', function () {
                resetForm();
                  $('#updateUser').attr('id', 'saveUser');
            });

            // Search functionality
            $('#searchBtn').click(function() {
                currentPage = 1;
                let searchKeyword = $('#searchInput').val();
                loadUsers(searchKeyword, currentPage, pageSize);
            });

            // Search on Enter keygit add .

            $('#searchInput').keypress(function(e) {
                if (e.which === 13) {
                    $('#searchBtn').click();
                    return false;
                }
            });

            // Status filter
            $('#statusFilter').change(function() {
                currentPage = 1;
                let searchKeyword = $('#searchInput').val();
                loadUsers(searchKeyword, currentPage, pageSize);
            });
        });

        /**
         * Tải danh sách người dùng
         */
        function loadUsers(searchKeyword, page, pageSize) {
            const formData = new FormData();
            formData.append('search', searchKeyword);
            formData.append('page', page);
            formData.append('pagesize', pageSize);

            listUserApi.post(formData, {
                hideModal: false,
                resetForm: false,
                showMessage: false,
                callback: function(response) {
                    if (response.success && response.data) {
                        renderUserTable(response.data);
                        renderPagination(response.totalPages, page);
                    }
                }
            });
        }

        /**
         * Render bảng người dùng
         */
        function renderUserTable(users) {
            let html = '';
            users.forEach((user, index) => {
                const statusBadge = user.isActive 
                    ? '<span class="badge bg-success">Hoạt động</span>' 
                    : '<span class="badge bg-danger">Khoá</span>';
                
                html += `
                    <tr>
                        <td>${index + 1}</td>
                        <td>${user.fullName}</td>
                        <td>${user.username}</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-info edit-btn" onclick="editUser('${user.id}')">
                                <i class="fas fa-edit"></i> Sửa
                            </button>
                  
                            <button class="btn btn-sm btn-danger" onclick="deleteUser('${user.id}', '${user.fullName}')">
                                <i class="fas fa-trash"></i> Xoá
                            </button>
                        </td>
                    </tr>
                `;
            });
            $('#userTableBody').html(html);
        }

        /**
         * Render pagination
         */
        function renderPagination(totalPages, currentPageNum) {
            let paginationHtml = '';
            
            // Previous button
            if (currentPageNum > 1) {
                paginationHtml += `<li class="page-item"><a class="page-link" href="#" onclick="changePage(${currentPageNum - 1})">Trước</a></li>`;
            }

            // Page numbers
            for (let i = 1; i <= totalPages; i++) {
                if (i === currentPageNum) {
                    paginationHtml += `<li class="page-item active"><span class="page-link">${i}</span></li>`;
                } else {
                    paginationHtml += `<li class="page-item"><a class="page-link" href="#" onclick="changePage(${i})">${i}</a></li>`;
                }
            }

            // Next button
            if (currentPageNum < totalPages) {
                paginationHtml += `<li class="page-item"><a class="page-link" href="#" onclick="changePage(${currentPageNum + 1})">Sau</a></li>`;
            }

            $('#pagination').html(paginationHtml);
            $('#paginationInfo').text(`Trang ${currentPageNum} / ${totalPages}`);
        }

        /**
         * Chuyển trang
         */
        function changePage(pageNum) {
            currentPage = pageNum;
            let searchKeyword = $('#searchInput').val();
            loadUsers(searchKeyword, currentPage, pageSize);
            return false;
        }

        /**
         * Chỉnh sửa người dùng
         */
        function editUser(userId) {
            editingUserId = userId;
           
            // Tạo API client để lấy thông tin người dùng
            const getApi = new ApiClient(`/api/chi-tiet-nguoi-dung/${userId}`);
            getApi.get({}, {
                callback: function(response) {
                    if (response.success && response.data) {
                        const user = response.data;
                        console.log('User data:', user);    
                        $('#userId').val(user.id);
                        $('#fullName').val(user.fullName);
                        $('#username').val(user.username);
                        $('#password').val(user.passwordHash); 
                        $('#password').removeAttr('required');
                        $('#passwordNote').show();
                        $('#addUserModalLabel').text('Chỉnh sửa người dùng');
                        $('#modalTitle').text('Chỉnh sửa người dùng');
                        $('#modal-add').modal('show');
                        $('#saveUser').attr('id', 'updateUser');
                      
                    
                    }
                }
            });
        }

        /**
         * Xóa người dùng
         */
        function deleteUser(userId, userName) {
            $('#deleteUserName').text(userName);
            $('#deleteUserModal').modal('show');
            $('#confirmDeleteBtn').off('click').click(function() {
                // Tạo API client để xoá người dùng
                
                const deleteApi = new ApiClient(`/api/xoa-nguoi-dung/${userId}`);
                deleteApi.delete({}, {
                    hideModal: true,
                    successMessage: 'Xoá người dùng thành công',
                    errorMessage: "Xoá thất bại!",

                    callback: function() {
                        
                        $('#deleteUserModal').modal('hide');
                        currentPage = 1;
                        loadUsers($('#searchInput').val(), currentPage, pageSize);

                    }
                });
            });
        }

    
        /**
         * Reset form thêm mới
         */
        function resetForm() {
            editingUserId = null;
            $('#userId').val('');
            $('#userForm')[0].reset();
            $('#password').attr('required', 'required');
            $('#passwordNote').hide();
            $('#addUserModalLabel').text('Thêm người dùng mới');
            $('#modalTitle').text('Thêm người dùng mới');
        }
           /**
         * cập nhật người dùng
         */
         function updateUser(userId) {
            const formData = new FormData($('#userForm')[0]);
            const updateApi = new ApiClient(`/api/cap-nhat-nguoi-dung/${userId}`);
            updateApi.put(formData, {
                successMessage: "Cập nhật người dùng thành công!",
                errorMessage: "Cập nhật thất bại!",
                hideModal: true,
                resetForm: true,
                callback: function(response) {
                    editingUserId = null;
                    currentPage = 1;
                    loadUsers($('#searchInput').val(), currentPage, pageSize);
                }
            });
         }

    </script>
}
@section Styles {
    <style>
        .required:after {
            content: " *";
            color: red;
        }

        .table-hover tbody tr:hover {
            background-color: #f5f5f5;
            cursor: pointer;
        }

        .page-item.active .page-link {
            background-color: #4e73df;
            border-color: #4e73df;
        }

        .bg-gradient-primary {
            background: linear-gradient(180deg, #4e73df 10%, #224abe 100%);
        }

        .badge {
            padding: 0.5rem 0.75rem;
            font-weight: 500;
        }

        .btn-sm {
            padding: 0.25rem 0.5rem;
        }
    </style>
}
