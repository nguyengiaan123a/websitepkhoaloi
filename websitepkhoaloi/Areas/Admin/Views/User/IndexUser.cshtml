

<!-- DataTales Example -->
<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex flex-row justify-content-between align-items-center bg-gradient-primary">
        <h6 class="m-0 font-weight-bold text-white">
            <i class="fas fa-users me-2"></i>Quản lý người dùng
        </h6>
        <button class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#modal-add">
            <i class="fas fa-plus-circle me-1"></i>Thêm người dùng
        </button>
    </div>
    <div class="card-body">
        <!-- Search and Filter Row -->
        <div class="row mb-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i class="fas fa-search text-primary"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm theo tên hoặc tài khoản...">
                    <button class="btn btn-outline-primary" type="button" id="searchBtn">
                        <i class="fas fa-search"></i> Tìm
                    </button>
                </div>
            </div>
            <div class="col-md-6 text-end">
                <select id="statusFilter" class="form-select w-auto d-inline-block">
                    <option value="">Tất cả trạng thái</option>
                    <option value="1">Hoạt động</option>
                    <option value="0">Khoá</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-bordered" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>STT</th>
                        <th>Họ và tên</th>
                        <th>Tên đăng nhập</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="userTableBody">
                    <!-- Data will be loaded here -->
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="row mt-3">
            <div class="col-md-6">
                <div class="text-muted small" id="paginationInfo"></div>
            </div>
            <div class="col-md-6">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-end" id="pagination">
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- Add User Modal -->
<div class="modal fade" id="modal-add" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="addUserModalLabel">
                    <i class="fas fa-user-plus me-2"></i>Thêm người dùng mới
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="userForm">
                    <div class="mb-3">
                        <label for="fullName" class="form-label required">Họ và tên</label>
                        <input type="text" class="form-control" id="fullName" name="fullName" required>
                        <div class="invalid-feedback">Vui lòng nhập họ tên</div>
                    </div>
                    <div class="mb-3">
                        <label for="username" class="form-label required">Tài khoản</label>
                        <input type="text" class="form-control" id="username" name="username" required>
                        <div class="invalid-feedback">Vui lòng nhập tài khoản</div>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label required">Mật khẩu</label>
                        <div class="input-group">
                            <input type="password" class="form-control" id="password" name="password" required>
                            <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <small class="text-muted">Mật khẩu phải có ít nhất 6 ký tự, bao gồm 1 chữ in hoa, 1 số và 1 ký tự đặc biệt</small>
                        <div class="invalid-feedback">Mật khẩu không hợp lệ</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Đóng
                </button>
                <button type="button" class="btn btn-primary" id="saveUser">
                    <i class="fas fa-save me-1"></i>Lưu
                </button>
            </div>
        </div>
    </div>
</div>



<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteUserModalLabel">
                    <i class="fas fa-trash-alt me-2"></i>Xác nhận xoá
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xoá người dùng <strong id="deleteUserName"></strong>?</p>
                <p class="text-danger mb-0"><small>Hành động này không thể hoàn tác!</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Huỷ
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fas fa-trash-alt me-1"></i>Xoá
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            let currentPage = 1;
            let pageSize = 10;
            let searchKeyword = '';
            let statusFilter = '';


       
            // Toggle password visibility
            $('#togglePassword').click(function () {
                const passwordInput = $('#password');
                const icon = $(this).find('i');
                if (passwordInput.attr('type') === 'password') {
                    passwordInput.attr('type', 'text');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                } else {
                    passwordInput.attr('type', 'password');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                }
            });

            // Save new user
            $('#saveUser').click(function() {
                let formData = new FormData($('#userForm')[0]);
                console.log(formData)
                $.ajax({
                    url: '/api/dang-ky-tai-khoan',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        if (response.success) {
                           
                            $('#modal-add').modal('hide');
                            $('#userForm')[0].reset();
                            swal.fire("Thành công", response.message, "success");
                        } else {
                            swal.fire("Thất bại", response.message, "error");
                        }
                    }
                });
            });

            // Load users with pagination
            function loadUsers(page = 1) {
                $.ajax({
                    url: '/api-get-users',
                    type: 'GET',
                    data: {
                        page: page,
                        pageSize: pageSize,
                        search: searchKeyword,
                        status: statusFilter
                    },
                    success: function (response) {
                        if (response.success) {
                            renderUserTable(response.data);
                            renderPagination(response.totalPages, response.currentPage);
                            $('#paginationInfo').html(`Hiển thị ${response.data.length} trên tổng số ${response.totalRecords} người dùng`);
                        }
                    },
                    error: function (xhr) {
                        console.error('Error loading users:', xhr);
                    }
                });
            }

            // Render user table
            function renderUserTable(users) {
                const tbody = $('#userTableBody');
                tbody.empty();

                if (users.length === 0) {
                    tbody.html('一分<td colspan="5" class="text-center">Không có dữ liệu</td></tr>');
                    return;
                }

                users.forEach((user, index) => {
                    const statusBadge = user.Status === 1
                        ? '<span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Hoạt động</span>'
                        : '<span class="badge bg-danger"><i class="fas fa-lock me-1"></i>Khoá</span>';

                    const row = `
                        <tr>
                            <td>${(currentPage - 1) * pageSize + index + 1}</td>
                            <td><strong>${escapeHtml(user.fullName)}</strong></td>
                            <td><code>${escapeHtml(user.username)}</code></td>
                            <td>${statusBadge}</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-warning me-1" onclick="editUser('${user.id}')" title="Sửa">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-danger" onclick="deleteUser('${user.id}', '${escapeHtml(user.fullName)}')" title="Xoá">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                    tbody.append(row);
                });
            }

            // Render pagination
            function renderPagination(totalPages, currentPage) {
                const pagination = $('#pagination');
                pagination.empty();

                if (totalPages <= 1) return;

                // Previous button
                pagination.append(`
                    <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                        <a class="page-link" href="#" onclick="changePage(${currentPage - 1}); return false;">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>
                `);

                // Page numbers
                for (let i = 1; i <= totalPages; i++) {
                    if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
                        pagination.append(`
                            <li class="page-item ${i === currentPage ? 'active' : ''}">
                                <a class="page-link" href="#" onclick="changePage(${i}); return false;">${i}</a>
                            </li>
                        `);
                    } else if (i === currentPage - 3 || i === currentPage + 3) {
                        pagination.append(`<li class="page-item disabled"><span class="page-link">...</span></li>`);
                    }
                }

                // Next button
                pagination.append(`
                    <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                        <a class="page-link" href="#" onclick="changePage(${currentPage + 1}); return false;">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                `);
            }

            window.changePage = function (page) {
                if (page >= 1 && page <= totalPages) {
                    currentPage = page;
                    loadUsers(page);
                }
            };

            window.editUser = function (userId) {
                $.ajax({
                    url: `/api-get-user/${userId}`,
                    type: 'GET',
                    success: function (response) {
                        if (response.success) {
                            $('#editUserId').val(response.data.id);
                            $('#editFullName').val(response.data.fullName);
                            $('#editUsername').val(response.data.username);
                            $('#editStatus').val(response.data.status);
                            $('#editUserModal').modal('show');
                        }
                    },
                    error: function () {
                        Swal.fire('Lỗi!', 'Không thể lấy thông tin người dùng', 'error');
                    }
                });
            };

            // Update user
            $('#updateUserBtn').click(function () {
                const userId = $('#editUserId').val();
                const formData = {
                    Id: userId,
                    FullName: $('#editFullName').val(),
                    Username: $('#editUsername').val(),
                    Status: parseInt($('#editStatus').val())
                };

                if (!formData.FullName || !formData.Username) {
                    Swal.fire('Lỗi!', 'Vui lòng điền đầy đủ thông tin', 'error');
                    return;
                }

                $.ajax({
                    url: '/api-update-user',
                    type: 'PUT',
                    contentType: 'application/json',
                    data: JSON.stringify(formData),
                    success: function (response) {
                        if (response.success) {
                            Swal.fire('Thành công!', response.message, 'success');
                            $('#editUserModal').modal('hide');
                            loadUsers(currentPage);
                        } else {
                            Swal.fire('Lỗi!', response.message, 'error');
                        }
                    },
                    error: function () {
                        Swal.fire('Lỗi!', 'Có lỗi xảy ra khi cập nhật', 'error');
                    }
                });
            });

            window.deleteUser = function (userId, userName) {
                $('#deleteUserName').text(userName);
                $('#deleteUserModal').modal('show');

                $('#confirmDeleteBtn').off('click').on('click', function () {
                    $.ajax({
                        url: `/api-delete-user/${userId}`,
                        type: 'DELETE',
                        success: function (response) {
                            if (response.success) {
                                Swal.fire('Thành công!', response.message, 'success');
                                $('#deleteUserModal').modal('hide');
                                loadUsers(currentPage);
                            } else {
                                Swal.fire('Lỗi!', response.message, 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Lỗi!', 'Có lỗi xảy ra khi xoá', 'error');
                        }
                    });
                });
            };

            function escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }
        });
    </script>
}
@section Styles {
    <style>
        .required:after {
            content: " *";
            color: red;
        }

        .table-hover tbody tr:hover {
            background-color: #f5f5f5;
            cursor: pointer;
        }

        .page-item.active .page-link {
            background-color: #4e73df;
            border-color: #4e73df;
        }

        .bg-gradient-primary {
            background: linear-gradient(180deg, #4e73df 10%, #224abe 100%);
        }

        .badge {
            padding: 0.5rem 0.75rem;
            font-weight: 500;
        }

        .btn-sm {
            padding: 0.25rem 0.5rem;
        }
    </style>
}
